# ==========================================
# 1. OS & Editor Specifics (macOS, Windows, VS Code)
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# VS Code
!.vscode/extensions.json
*.code-workspace
.history/
.ionide/
AGENTS.md

# ==========================================
# 2. STM32 / Embedded Compiler Outputs
# ==========================================
# Ignore build directories generated by CubeIDE, Make, or CMake
firmware/data_logger/build/
firmware/data_logger/Debug/
firmware/data_logger/Release/
firmware/inference/build/
firmware/inference/Debug/
firmware/inference/Release/

# Toolchain / IDE specific configuration files that shouldn't be shared
firmware/data_logger/*.launch
firmware/inference/*.launch
.pico-sdk/

# Compiled Binary Formats (Firmware images)
*.elf
*.bin
*.hex
*.axf
*.srec
*.symbols

# Map and listing files (linker details)
*.map
*.lst

# Object and dependency files
*.o
*.su
*.d

# ==========================================
# 3. Python & Jupyter Pipeline
# ==========================================
# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Local Virtual Environments
.venv/
venv/
env/
ENV/
pipeline/.venv/
pipeline/venv/
pipeline/env/
pipeline/ENV/

# Jupyter Notebook checkpoints and state
pipeline/.ipynb_checkpoints/
.ipynb_checkpoints/